{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "urbania/api",
    "type": "project",
    "description": "Urbania API — Laravel RESTful API with Clean Architecture + DDD.",
    "keywords": ["laravel", "framework", "ddd", "urbania"],
    "license": "MIT",
    "require": {
        "php": "^8.5",
        "egulias/email-validator": "^4.0",
        "knuckleswtf/scribe": "^5.10",
        "laravel/framework": "^13.0",
        "laravel/tinker": "^3.0",
        "php-open-source-saver/jwt-auth": "^2.9",
        "pragmarx/google2fa-laravel": "*",
        "ramsey/uuid": "^4.7"
    },
    "require-dev": {
        "fakerphp/faker": "^1.23",
        "larastan/larastan": "^3.0",
        "laravel/pail": "^1.2.5",
        "laravel/pint": "^1.29",
        "mockery/mockery": "^1.6",
        "nunomaduro/collision": "^8.6",
        "pestphp/pest": "^4.4",
        "pestphp/pest-plugin-laravel": "^4.1",
        "phpstan/phpstan": "^2.2"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Directorio\\": "src/Directorio/",
            "Urbania\\": "src/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/",
            "Urbania\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "vendor/bin/pest",
        "test:unit": "vendor/bin/pest --filter=Unit",
        "test:integration": "vendor/bin/pest --filter=Integration",
        "test:feature": "vendor/bin/pest --filter=Feature",
        "test:security": "vendor/bin/pest --filter=Security",
        "test:coverage": "vendor/bin/pest --coverage --min=80",
        "stan": "php -d memory_limit=2G vendor/bin/phpstan analyse",
        "lint": "vendor/bin/pint --test",
        "fmt": "vendor/bin/pint",
        "migrate": "php artisan migrate",
        "migrate:fresh": "php artisan migrate:fresh",
        "migrate:rollback": "php artisan migrate:rollback",
        "seed": "php artisan db:seed",
        "rollback": "php artisan migrate:rollback",
        "scribe": "php artisan scribe:generate",
        "ci": [
            "@lint",
            "@stan",
            "@test"
        ],
        "clean-migrations": "@php -r \"array_map('unlink', glob('database/migrations/*'));\"",
        "create-dirs": "@php scripts/setup_dirs.php",
        "key-generate": "@php artisan key:generate",
        "publish-jwt": "@php artisan vendor:publish --provider=\"PHPOpenSourceSaver\\JWTAuth\\Providers\\LaravelServiceProvider\"",
        "publish-scribe": "@php artisan vendor:publish --tag=scribe-config",
        "generate-jwt-keys": "@php scripts/generate_jwt_keys.php",
        "docker-up": "docker compose up -d --build",
        "docker-rebuild": "docker compose build --no-cache && docker compose up -d",
        "docker-down": "docker compose down",
        "docker-down-v": "docker compose down -v",
        "docker-logs": "docker compose logs -f",
        "create-test-db": "docker compose exec -T db createdb urbania_test -U urbania",
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "pre-package-uninstall": [
            "Illuminate\\Foundation\\ComposerScripts::prePackageUninstall"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "process-timeout": 1200
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
